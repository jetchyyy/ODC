rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    match /contactSubmissions/{docId} {
      allow create: if
        request.resource.data.name is string && request.resource.data.name.size() > 0 &&
        request.resource.data.email is string && request.resource.data.email.size() > 0 &&
        request.resource.data.goal is string && request.resource.data.goal.size() > 0 &&
        request.resource.data.submittedAt == request.time &&
        request.resource.data.keys().hasOnly([
          'name', 'email', 'company', 'goal', 'submittedAt', 'userAgent', 'referrer'
        ]);

      allow read, delete: if request.auth != null;
      allow update: if false;
    }

    match /invoices/{docId} {
      allow read, create, update, delete: if request.auth != null;
    }

    match /moas/{docId} {
      allow read, create, update, delete: if request.auth != null;
    }

    match /supportTickets/{ticketId} {
      allow read, create, update, delete: if request.auth != null;
      
      match /messages/{messageId} {
        allow read, create, update, delete: if request.auth != null;
      }
    }

    match /clients/{docId} {
      allow read, create, update, delete: if request.auth != null;
    }

    match /maintenanceSettings/{docId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /serviceInquiries/{docId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
